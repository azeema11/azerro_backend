# Database Configuration
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
POSTGRES_USER=postgres_user
POSTGRES_PASSWORD=postgres_password
POSTGRES_DB=postgres_db

# Server Configuration
PORT=3000
NODE_ENV="development"
JWT_SECRET=your_jwt_secret_here

# External API Keys - Stock & Financial Data
FINNHUB_API_KEY=your_finnhub_key
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key

# External API Keys - Metals & Commodities
METALS_DEV_API_KEY=your_metals_dev_key
GOLD_API_ACCESS_TOKEN=your_gold_api_key

# AI Configuration
OLLAMA_MODEL_ENDPOINT=your_ollama_model_endpoint
GEMINI_API_KEY=gemini_api_key

# ADK Agent Configuration
AI_PROVIDER=your_ai_provider
AI_MODEL=your_ai_model
OLLAMA_BASE_URL=your_ollama_base_url

# Redis
REDIS_URL=redis://redis:6379

# Holdings Refresh Job Configuration
HOLDING_REFRESH_CRON=cron_expression
HOLDING_CONCURRENCY_LIMIT=concurrency_limit

# Database Maintenance Configuration
DB_MAINTENANCE_FULL_VACUUM=true/false
DB_MAINTENANCE_REINDEX=true/false

# INDMoney Broker Configuration
INDMONEY_AUTH_URL=https://mcp.indmoney.com/authorize
INDMONEY_TOKEN_URL=https://mcp.indmoney.com/token
INDMONEY_MCP_URL=https://mcp.indmoney.com/mcp
INDMONEY_CLIENT_ID=your_indmoney_client_id_here
INDMONEY_CLIENT_SECRET=your_indmoney_client_secret_here

API_BASE_URL=base_url
